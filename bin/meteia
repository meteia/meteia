#!/usr/bin/env php
<?php

declare(strict_types=1);

use Meteia\Bootstrap\ApplicationPath;
use Meteia\Bootstrap\ComposerAutoload;
use Meteia\CommandLine\ConsoleKernel;
use Meteia\ValueObjects\Identity\FilesystemPath;

require $_composer_autoload_path ?? implode(DIRECTORY_SEPARATOR, [__DIR__, '..', 'vendor', 'autoload.php']);

$autoload = new ComposerAutoload(new FilesystemPath('composer.json'));
$kernel = new ConsoleKernel(
    $autoload->primaryNamespace(),
    new ApplicationPath('.'),
    new ApplicationPath(__DIR__, '..'),
);

exit($kernel->run());
